{
  "info": {
    "_postman_id": "c3d4e5f6-g7h8-9012-ijkl-mn3456789012",
    "name": "Property Update - Admin",
    "description": "APIs for admins to manage and review property update requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Pending Update Requests",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/property-updates/admin/pending?page=0&size=10&sort=submittedAt,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "property-updates", "admin", "pending"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            },
            {
              "key": "sort",
              "value": "submittedAt,desc"
            }
          ]
        },
        "description": "Get all pending property update requests (admin only)"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has content array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('content');",
              "    pm.expect(jsonData.content).to.be.an('array');",
              "});",
              "",
              "pm.test(\"All requests are pending\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.content && jsonData.content.length > 0) {",
              "        jsonData.content.forEach(function(request) {",
              "            pm.expect(request.status).to.eql('PENDING');",
              "        });",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Pending Admin Review Requests",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/property-updates/admin/pending-review?page=0&size=10&sort=submittedAt,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "property-updates", "admin", "pending-review"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            },
            {
              "key": "sort",
              "value": "submittedAt,desc"
            }
          ]
        },
        "description": "Get all pending property update requests that need admin review"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has content array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('content');",
              "    pm.expect(jsonData.content).to.be.an('array');",
              "});",
              "",
              "pm.test(\"All requests need admin review\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.content && jsonData.content.length > 0) {",
              "        jsonData.content.forEach(function(request) {",
              "            pm.expect(request.adminReviewed).to.be.false;",
              "            pm.expect(request.status).to.eql('PENDING');",
              "        });",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Review Update Request (Admin Approve)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestId\": {{updateRequestId}},\n  \"approved\": true,\n  \"reviewerType\": \"ADMIN\",\n  \"notes\": \"Approved from admin side\",\n  \"rejectionReason\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/property-updates/admin/review",
          "host": ["{{baseUrl}}"],
          "path": ["api", "property-updates", "admin", "review"]
        },
        "description": "Approve a property update request as an admin"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Request is approved\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData.status).to.eql('APPROVED');",
              "    pm.expect(jsonData).to.have.property('adminReviewed');",
              "    pm.expect(jsonData.adminReviewed).to.be.true;",
              "    pm.expect(jsonData).to.have.property('adminApproved');",
              "    pm.expect(jsonData.adminApproved).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Review Update Request (Admin Reject)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestId\": {{updateRequestId}},\n  \"approved\": false,\n  \"reviewerType\": \"ADMIN\",\n  \"notes\": \"Cannot approve this update\",\n  \"rejectionReason\": \"The property details violate platform guidelines. Please revise and resubmit.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/property-updates/admin/review",
          "host": ["{{baseUrl}}"],
          "path": ["api", "property-updates", "admin", "review"]
        },
        "description": "Reject a property update request as an admin"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Request is rejected\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData.status).to.eql('REJECTED');",
              "    pm.expect(jsonData).to.have.property('adminReviewed');",
              "    pm.expect(jsonData.adminReviewed).to.be.true;",
              "    pm.expect(jsonData).to.have.property('adminApproved');",
              "    pm.expect(jsonData.adminApproved).to.be.false;",
              "    pm.expect(jsonData).to.have.property('rejectionReason');",
              "    pm.expect(jsonData.rejectionReason).to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
} 