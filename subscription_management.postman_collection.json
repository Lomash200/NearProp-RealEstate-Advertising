    {
      "name": "Payment Integration",
      "description": "Endpoints for payment processing with Razorpay gateway",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
