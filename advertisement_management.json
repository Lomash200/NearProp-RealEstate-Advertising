        {
            "name": "Set Advertisement Active Status",
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/v1/advertisements/{{advertisementId}}/active/true",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "advertisements",
                        "{{advertisementId}}",
                        "active",
                        "true"
                    ]
                },
                "description": "Activates or deactivates an advertisement. Only the creator or an admin can change the status.\n\n**Path Parameters:**\n- `advertisementId`: ID of the advertisement\n- `status`: true to activate, false to deactivate\n\n**Required Auth:**\n- Bearer token (admin or creator of the advertisement)"
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Parse the response",
                            "var jsonData = JSON.parse(responseBody);",
                            "",
                            "// Check if the request was successful",
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Advertisement status updated successfully\", function () {",
                            "    pm.expect(jsonData.active).to.equal(true);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
