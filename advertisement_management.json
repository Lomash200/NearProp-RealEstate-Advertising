{
    "name": "Advertisement Management",
    "description": "Endpoints for creating, updating, and managing advertisements",
    "item": [
        {
            "name": "Create Advertisement",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Exclusive Real Estate Offer\",\n    \"description\": \"Special offer on premium properties in central location. Contact us for exclusive deals.\",\n    \"bannerImageUrl\": \"https://example.com/images/banner.jpg\",\n    \"websiteUrl\": \"https://example.com\",\n    \"whatsappNumber\": \"+919876543210\",\n    \"targetLocation\": \"Indore, Madhya Pradesh\",\n    \"latitude\": 22.7196,\n    \"longitude\": 75.8577,\n    \"radiusKm\": 10.0,\n    \"districtId\": 1,\n    \"validFrom\": \"{{$isoTimestamp}}\",\n    \"validUntil\": \"{{$isoTimestampXDaysFromNow(30)}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/v1/advertisements",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "advertisements"
                    ]
                },
                "description": "Creates a new advertisement. Only admins can create advertisements.\n\n**Request Body:**\n- `title`: Title of the advertisement\n- `description`: Description of the advertisement\n- `bannerImageUrl`: URL of the banner image\n- `websiteUrl`: Optional website URL\n- `whatsappNumber`: Optional WhatsApp contact number\n- `targetLocation`: Location description for targeting\n- `latitude`: Latitude for geo-targeting\n- `longitude`: Longitude for geo-targeting\n- `radiusKm`: Radius in kilometers for geo-targeting\n- `districtId`: ID of the district to target (optional)\n- `districtName`: Name of the district if districtId not provided (optional)\n- `validFrom`: Start date for the advertisement validity\n- `validUntil`: End date for the advertisement validity\n\n**Required Auth:**\n- Bearer token (admin only)"
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Parse the response",
                            "var jsonData = JSON.parse(responseBody);",
                            "",
                            "// Check if the request was successful",
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test(\"Advertisement created successfully\", function () {",
                            "    pm.expect(jsonData).to.have.property(\"id\");",
                            "    pm.expect(jsonData).to.have.property(\"title\");",
                            "    pm.expect(jsonData).to.have.property(\"description\");",
                            "});",
                            "",
                            "// Store advertisement ID for later use",
                            "if (jsonData.id) {",
                            "    pm.environment.set(\"advertisementId\", jsonData.id);",
                            "    console.log(\"Advertisement ID stored: \" + jsonData.id);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Update Advertisement",
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"title\": \"Updated Real Estate Offer\",\n    \"description\": \"Updated offer on premium properties in central location. Limited time offer!\",\n    \"bannerImageUrl\": \"https://example.com/images/updated-banner.jpg\",\n    \"websiteUrl\": \"https://example.com/updated\",\n    \"whatsappNumber\": \"+919876543210\",\n    \"targetLocation\": \"Indore, Madhya Pradesh\",\n    \"latitude\": 22.7196,\n    \"longitude\": 75.8577,\n    \"radiusKm\": 15.0,\n    \"districtId\": 1,\n    \"validFrom\": \"{{$isoTimestamp}}\",\n    \"validUntil\": \"{{$isoTimestampXDaysFromNow(45)}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/v1/advertisements/{{advertisementId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "advertisements",
                        "{{advertisementId}}"
                    ]
                },
                "description": "Updates an existing advertisement. Only the creator or an admin can update an advertisement.\n\n**Path Parameters:**\n- `advertisementId`: ID of the advertisement to update\n\n**Request Body:**\n- Same fields as in Create Advertisement\n\n**Required Auth:**\n- Bearer token (admin or creator of the advertisement)"
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Parse the response",
                            "var jsonData = JSON.parse(responseBody);",
                            "",
                            "// Check if the request was successful",
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Advertisement updated successfully\", function () {",
                            "    pm.expect(jsonData.title).to.equal(\"Updated Real Estate Offer\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
