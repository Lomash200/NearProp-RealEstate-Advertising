    {
      "name": "District Revenue Management",
      "description": "Endpoints for managing revenue from franchisee districts",
      "item": [
        {
          "name": "Record District Revenue",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/franchisee/revenue/record?districtId={{districtId}}&franchiseeDistrictId={{franchiseeDistrictId}}&revenueType=COMMISSION&amount=5000&description=Property Sale Commission&propertyId={{propertyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "franchisee", "revenue", "record"],
              "query": [
                {
                  "key": "districtId",
                  "value": "{{districtId}}"
                },
                {
                  "key": "franchiseeDistrictId",
                  "value": "{{franchiseeDistrictId}}"
                },
                {
                  "key": "revenueType",
                  "value": "COMMISSION"
                },
                {
                  "key": "amount",
                  "value": "5000"
                },
                {
                  "key": "description",
                  "value": "Property Sale Commission"
                },
                {
                  "key": "propertyId",
                  "value": "{{propertyId}}"
                }
              ]
            },
            "description": "Record revenue for a district managed by a franchisee.\n\n**Query Parameters:**\n- `districtId`: ID of the district\n- `franchiseeDistrictId`: ID of the franchisee district assignment\n- `revenueType`: Type of revenue (COMMISSION, SUBSCRIPTION, OTHER)\n- `amount`: Amount of revenue\n- `description`: Description of the revenue\n- `propertyId`: ID of the related property (optional)\n- `subscriptionId`: ID of the related subscription (optional)\n\n**Required Auth:**\n- Bearer token with ADMIN role"
          },
          "response": []
        },
        {
          "name": "Get Revenue by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
