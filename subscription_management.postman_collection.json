            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 999.00,\n    \"currency\": \"INR\",\n    \"paymentType\": \"SUBSCRIPTION\",\n    \"subscriptionPlanId\": 1,\n    \"propertyId\": 123,\n    \"autoRenew\": true,\n    \"customerName\": \"Test User\",\n    \"customerEmail\": \"user@example.com\",\n    \"customerPhone\": \"9876543210\",\n    \"successUrl\": \"https://nearprop.com/payment/success\",\n    \"failureUrl\": \"https://nearprop.com/payment/failure\"\n}"
            },
