{
    "name": "Property Advertisements",
    "description": "Endpoints for retrieving advertisements related to properties",
    "item": [
        {
            "name": "Get Advertisements for Property",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/v1/properties/{{propertyId}}/advertisements?limit=3",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "properties",
                        "{{propertyId}}",
                        "advertisements"
                    ],
                    "query": [
                        {
                            "key": "limit",
                            "value": "3"
                        }
                    ]
                },
                "description": "Retrieves advertisements relevant to a specific property, based on its district.\n\n**Path Parameters:**\n- `propertyId`: ID of the property\n\n**Query Parameters:**\n- `limit`: Maximum number of advertisements to return (default: 3)\n\n**No auth required**"
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Parse the response",
                            "var jsonData = JSON.parse(responseBody);",
                            "",
                            "// Check if the request was successful",
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test(\"Property advertisements retrieved successfully\", function () {",
                            "    pm.expect(jsonData).to.be.an(\"array\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
