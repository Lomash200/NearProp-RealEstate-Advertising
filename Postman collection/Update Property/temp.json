            },
            {
              "key": "bedrooms",
              "value": "3",
              "description": "Number of bedrooms",
              "type": "text"
            },
            {
              "key": "bathrooms",
              "value": "2",
              "description": "Number of bathrooms",
              "type": "text"
            },
            {
              "key": "garages",
              "value": "1",
              "description": "Number of garages",
              "type": "text"
            },
            {
              "key": "address",
              "value": "123 Main Street, Indore",
              "description": "Property address",
              "type": "text"
            },
            {
              "key": "amenities",
              "value": "[\"Swimming Pool\", \"Gym\", \"Security\", \"Power Backup\"]",
              "description": "Property amenities as JSON array",
              "type": "text"
            },
            {
              "key": "securityFeatures",
              "value": "[\"CCTV\", \"Gated Community\", \"24x7 Security\"]",
